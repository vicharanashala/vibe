# ─────────────────────────────────────────────────────────────────────────────
# ViBe Backend — Local Development Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development:
#   cp .example.env .env          (macOS / Linux)
#   copy .example.env .env        (Windows CMD)
#   Copy-Item .example.env .env   (Windows PowerShell)
#
# All values below are pre-configured for the LOCAL dev stack.
# The run-all.ps1 / run-all.sh startup scripts will auto-correct any
# mismatches (e.g. Firebase project ID) automatically on first run.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_PORT="3141"
APP_MODULE="all"

APP_URL="http://localhost:3141"
APP_ORIGINS="http://localhost:5173,http://localhost:3141"

# ── Database ─────────────────────────────────────────────────────────────────
# For local dev the CLI auto-starts a MongoDB Memory Server on port 27017.
# You do NOT need a real MongoDB installation.
DB_URL="mongodb://localhost:27017/vibe?tls=false"
DB_NAME="vibe"
MONGOMS_DEBUG="false"

# ── Firebase Auth Emulator ───────────────────────────────────────────────────
# These values enable the local Firebase Auth Emulator.
# The project ID below must match the one in backend/.firebaserc.
# The run-all script validates and auto-fixes this automatically.
FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
FIREBASE_EMULATOR_HOST="127.0.0.1:4000"
GCLOUD_PROJECT="vibe-5b35a"

FIREBASE_PROJECT_ID=vibe-5b35a
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@vibe-5b35a.iam.gserviceaccount.com
# For local dev with the emulator, this private key is intentionally a placeholder.
# The emulator does NOT verify service account credentials.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG9w0BAQEFAASCBKYwggSiAgEAAoIBAQC7PLACEHOLDER\n-----END PRIVATE KEY-----\n"

# ── Optional / Production Only ───────────────────────────────────────────────
# Leave these blank for local development.
# FIREBASE_API_KEY=         # Only needed in production (login endpoint)
# SENTRY_DSN=               # Error monitoring (production only)
# INTEGRATION_API_KEY=      # Server-to-server integration (production only)
# GCP_BACKUP_BUCKET=        # GCS backup bucket (production only)
