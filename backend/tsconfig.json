{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "baseUrl": "src",
    "target": "ES6",
    "module": "nodenext",
    "moduleResolution": "Node16",
    "jsx": "react-jsx",
      "lib": ["ESNext"],
    "outDir": "build",

    // Changed back to "." to include scripts directory
    "rootDir": "src",

    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,

    // Set `sourceRoot` to  "/" to strip the build path prefix
    // from generated source code references.
    // This improves issue grouping in Sentry.
    "sourceRoot": "D:/vibe/backend/src",

    "resolveJsonModule": true,
    "allowArbitraryExtensions": false,
    "incremental": true,

    "paths": {
      "#root/*": ["./*"],
      "#shared/*": ["./shared/*"],
      "#auth/*": ["./modules/auth/*"],
      "#courses/*": ["./modules/courses/*"],
      "#users/*": ["./modules/users/*"],
      "#quizzes/*": ["./modules/quizzes/*"],
      "#settings/*": ["./modules/settings/*"],
      "#ejectionPolicy/*": ["./modules/ejectionPolicy/*"]
    },

    "types": ["node", "express"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "inlineSources": true
  },
  "exclude": ["build", "dist", "**/*.spec.ts", "**/*.d.ts", "vite.config.ts"],
  "include": ["src/**/*.ts"]
}
