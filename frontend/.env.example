# Frontend Environment Variables (Development)
# Copy this file to .env and fill in the values for your Firebase project.
#
# For LOCAL DEVELOPMENT using the Firebase Auth Emulator, all values below
# are pre-filled with safe placeholder values — the emulator accepts them
# without a real Firebase project.
#
# For PRODUCTION, replace every value with the real credentials from your
# Firebase Console (Project Settings -> General -> Your Apps -> Web App).

# Firebase Project Configuration
VITE_FIREBASE_API_KEY=local-dev-api-key
VITE_FIREBASE_AUTH_DOMAIN=vibe-5b35a.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=vibe-5b35a
VITE_FIREBASE_STORAGE_BUCKET=vibe-5b35a.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:local-dev-app-id

# Backend API Base URL
VITE_BASE_URL=http://localhost:3141/api
